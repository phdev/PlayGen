# Orchestrator
ANTHROPIC_API_KEY=

# Concept image step (premise -> concept.png)
OPENAI_API_KEY=
PLAYGEN_IMAGE_MODEL=gpt-image-2

# Image -> rigged glTF
MESHY_API_KEY=

# PlayCanvas REST (asset upload, since the editor MCP server can't push binaries)
PLAYCANVAS_API_KEY=
PLAYCANVAS_PROJECT_ID=

# Editor MCP server: runs locally; expose port for the Chrome extension
PLAYCANVAS_MCP_PORT=52000

# Harness
PLAYWRIGHT_HEADLESS=true
